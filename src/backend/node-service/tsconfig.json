{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "paths": {
      "@shared/*": ["../../shared/types/*"]
    },
    "types": ["vitest/globals"]
  },
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  }
}
