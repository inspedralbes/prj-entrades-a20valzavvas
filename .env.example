# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=entrades
POSTGRES_PASSWORD=entrades_secret
POSTGRES_DB=entrades
# Host port exposed for PostgreSQL (change to e.g. 5433 if 5432 is already in use locally)
DB_PORT=5432

# ─── Backend (NestJS) ─────────────────────────────────────────────────────────
# Inside Docker Compose the host is the service name 'db'
DATABASE_URL=postgresql://entrades:entrades_secret@db:5432/entrades
BACKEND_PORT=3001

# ─── Frontend (Nuxt 3) ────────────────────────────────────────────────────────
FRONTEND_PORT=3000
